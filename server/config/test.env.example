# Test profile example
LCS_PROFILE=test
LCS_HOST=127.0.0.1
LCS_PORT=8100
LCS_RELOAD=false
LCS_LOG_LEVEL=warning
LCS_DATABASE_URL=sqlite:///data/sqlite/local_chat_test.db
LCS_STORAGE_ROOT=data
LCS_ALLOWED_ORIGINS=http://localhost:3000
LCS_SESSION_SECRET=test-secret-not-for-production
LCS_REQUEST_TIMEOUT_MS=5000
LCS_RATE_LIMIT_WINDOW_MS=60000
LCS_RATE_LIMIT_MAX_REQUESTS=240
LCS_AUTH_RATE_LIMIT_WINDOW_MS=60000
LCS_AUTH_RATE_LIMIT_MAX_REQUESTS=30
LCS_BRUTEFORCE_WINDOW_MS=900000
LCS_BRUTEFORCE_LOGIN_ATTEMPT_LIMIT=5
LCS_BRUTEFORCE_IP_ATTEMPT_LIMIT=25
LCS_BRUTEFORCE_BLOCK_MS=900000
